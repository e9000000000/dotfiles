# devices
output DVI-D-1 mode 1920x1080@144Hz

input * {
    xkb_layout "us,ru"
    xkb_options "caps:escape,grp:alt_shift_toggle"
}

input type:keyboard {
    repeat_delay 190
    repeat_rate 20
}

input type:pointer {
    pointer_accel -1
}

# hide cursor when not moving it
seat * hide_cursor 2000

# workspaces
set $ws1 "1:<"
set $ws2 "2:3"
set $ws3 "3:?"
set $ws4 "4:$"
set $ws5 "5:%"
set $ws6 "6:^"
set $ws7 "7:@"
set $ws8 "8:#"
set $ws9 "9:&"

# colors
set $opacity_bg_color #282828
set $bg_color #282828
set $fg_color #928374
set $urgent_color #fabd2f
set $tx_color #ebdbb2

# variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $screenshot flameshot gui

# autostart
exec flameshot
exec alacritty -e tmux a
exec firefox
exec telegram-desktop
exec pipewire -c ~/.config/pipewire/nonoice.conf

# wallpapers
output * bg #282828 solid_color

# borders
default_border pixel 1
default_floating_border none
smart_borders on

# special windows settings
assign [app_id="firefox"] $ws1
assign [app_id="Alacritty"] $ws2
assign [app_id="telegramdesktop"] $ws8
assign [title="Discord"] $ws9
for_window [class="feh"] floating enable

# window status         border    bg        text      indicator   child_border
client.focused          $fg_color $fg_color $tx_color $bg_color   $fg_color
client.focused_inactive $bg_color $bg_color $tx_color $bg_color   $bg_color
client.unfocused        $bg_color $bg_color $tx_color $bg_color   $bg_color
client.urgent           $fg_color $fg_color $tx_color $bg_color   $fg_color
client.placeholder      $bg_color $bg_color $tx_color $bg_color   $bg_color

# keybinds
bindsym $mod+s exec $screenshot
bindsym $mod+q kill
bindsym $mod+d exec wofi
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exec swaymsg exit

floating_modifier $mod normal

bindsym $mod+b splith
bindsym $mod+v splitv

bindsym $mod+e layout toggle split
bindsym $mod+w layout tabbed

bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9

bindsym $mod+f floating toggle
bindsym $mod+Shift+f fullscreen

bindsym $mod+r mode "resize"
mode "resize" {
    bindsym $left resize shrink width 20px
    bindsym $down resize grow height 20px
    bindsym $up resize shrink height 20px
    bindsym $right resize grow width 20px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}

# bar
bar {
    position top
    font DejaVu Sans 10.5
    status_command while date +'%H:%M  %A %b %d'; do sleep 1; done
    status_edge_padding 3
    status_padding 0
    strip_workspace_numbers yes
    colors {
        statusline $tx_color
        background $opacity_bg_color
        separator $fg_color
        focused_background $opacity_bg_color
        focused_statusline $tx_color
        focused_workspace $bg_color $bg_color $tx_color
        inactive_workspace $bg_color $bg_color $fg_color
        urgent_workspace $bg_color $bg_color $urgent_color
        binding_mode $bg_color $bg_color $urgent_color
    }
}

# some strange stuff, don't know what is it
exec systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK
exec hash dbus-update-activation-environment 2>/dev/null && \
     dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK
