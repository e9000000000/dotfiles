{
    "configurations": {
        "python run current file": {
            "adapter": "debugpy",
            "filetypes": ["python"],
            "default": false,
            "breakpoints": {
                "exception": {
                    "raised": "N",
                    "uncaught": "Y"
                }
            },
            "configuration": {
                "request": "launch",
                "program": "${file}",
                "cwd": "${fileDirname}",
                "console": "externalTerminal"
            }
        },
        "python run __main__.py": {
            "adapter": "debugpy",
            "filetypes": ["python"],
            "default": false,
            "breakpoints": {
                "exception": {
                    "raised": "N",
                    "uncaught": "Y"
                }
            },
            "configuration": {
                "request": "launch",
                "program": "${workspaceRoot}/__main__.py",
                "cwd": "${workspaceRoot}",
                "console": "externalTerminal"
            }
        },
        "python attach": {
            "adapter": "multi-session",
            "filetypes": ["python"],
            "default": false,
            "breakpoints": {
                "exception": {
                    "raised": "N",
                    "uncaught": "Y",
                    "userUnhandled": "Y"
                }
            },
            "configuration": {
                "request": "attach",
                "pathMappings": [
                    {
                        "localRoot": "${workspaceRoot}",
                        "remoteRoot": "${remoteRoot}"
                    }
                ]
            }
        }
    }
}
