    "editor.tokenColorCustomizations": {
        "[generated-dark]": {
            "textMateRules": [
                {
                    "scope": "invalid",
                    "settings": {
                        "foreground": "#F07171"
                    }
                },
                {
                    "scope": [
                        "meta.embedded",
                        "source.groovy.embedded",
                        "meta.template.expression"
                    ],
                    "settings": {
                        "foreground": "#fffff9"
                    }
                },
                {
                    "scope": [
                        "variable",
                        "punctuation.definition.variable",
                        "support.variable.property.dom",
                        "support.variable.dom",
                        "support.variable.property",
                        "punctuation.separator.parameter",
                        "string.interpolated.pug variable"
                    ],
                    "settings": {
                        "foreground": "#fffff9"
                    }
                },
                {
                    "scope": [
                        "comment",
                        "punctuation.definition.comment"
                    ],
                    "settings": {
                        "foreground": "#000000"
                    }
                },
                {
                    "scope": [
                        "string",
                        "punctuation.definition.string"
                    ],
                    "settings": {
                        "foreground": "#0ed839"
                    }
                },
                {
                    "scope": "constant.character.escape",
                    "settings": {
                        "foreground": "#707070"
                    }
                },
                {
                    "scope": [
                        "keyword",
                        "constant.language.import-export-all"
                    ],
                    "settings": {
                        "foreground": "#505050"
                    }
                },
                {
                    "scope": [
                        "entity.name.type",
                        "support.type.primitive",
                        "support.type.builtin",
                        "meta.type.annotation entity.name.type",
                        "meta.type.parameters entity.name.type"
                    ],
                    "settings": {
                        "foreground": "#f996e2"
                    }
                },
                {
                    "scope": [
                        "keyword.control",
                        "keyword.operator",
                        "storage",
                        "support.type",
                        "keyword.operator.expression",
                        "keyword.operator.new"
                    ],
                    "settings": {
                        "foreground": "#707070"
                    }
                },
                {
                    "scope": [
                        "entity.name.function",
                        "support.class",
                        "support.function",
                        "new.expr entity.name.type",
                        "entity.other.inherited-class"
                    ],
                    "settings": {
                        "foreground": "#f996e2"
                    }
                },
                {
                    "scope": [
                        "punctuation.definition.typeparameters",
                        "keyword.operator.type",
                        "keyword.operator.optional",
                        "punctuation.definition.template-expression",
                        "source.tsx punctuation.section.embedded",
                        "source.jsx punctuation.section.embedded"
                    ],
                    "settings": {
                        "foreground": "#ff0000"
                    }
                },
                {
                    "scope": "constant",
                    "settings": {
                        "foreground": "#f996e2"
                    }
                },
                {
                    "scope": [
                        "constant.numeric",
                        "constant.language"
                    ],
                    "settings": {
                        "foreground": "#0e8ed8"
                    }
                },
                {
                    "scope": [
                        "variable.parameter",
                        "parameter.variable",
                        "meta.function.parameter variable",
                        "source.rust meta.type_params.rust"
                    ],
                    "settings": {
                        "foreground": "#0e8ed8"
                    }
                },
                {
                    "scope": [
                        "punctuation",
                        "meta.brace"
                    ],
                    "settings": {
                        "foreground": "#bfbfbb"
                    }
                },
                {
                    "scope": [
                        "variable.language.this",
                        "variable.language.special.self"
                    ],
                    "settings": {
                        "foreground": "#707070"
                    }
                },
                {
                    "scope": "comment.block.documentation entity.name.type",
                    "settings": {
                        "foreground": "#ff0000"
                    }
                },
                {
                    "scope": "variable.language.super",
                    "settings": {
                        "foreground": "#f996e2"
                    }
                },
                {
                    "scope": [
                        "meta.tag.metadata.doctype entity.name.tag",
                        "meta.tag.metadata.doctype punctuation.definition.tag",
                        "meta.tag.metadata.doctype string",
                        "meta.tag.metadata.doctype entity.other.attribute-name.html",
                        "meta.tag.sgml.doctype"
                    ],
                    "settings": {
                        "foreground": "#bfbfbb"
                    }
                },
                {
                    "scope": "entity.name.tag",
                    "settings": {
                        "foreground": "#707070"
                    }
                },
                {
                    "scope": "meta.tag string",
                    "settings": {
                        "foreground": "#0ed839"
                    }
                },
                {
                    "scope": [
                        "meta.tag entity.other.attribute-name",
                        "entity.other.attribute-name.html"
                    ],
                    "settings": {
                        "foreground": "#505050"
                    }
                },
                {
                    "scope": [
                        "constant.character.entity",
                        "punctuation.definition.entity"
                    ],
                    "settings": {
                        "foreground": "#0e8ed8"
                    }
                },
                {
                    "scope": [
                        "entity.name.section.markdown",
                        "markup.heading.setext"
                    ],
                    "settings": {
                        "foreground": "#505050"
                    }
                },
                {
                    "scope": "punctuation.definition.list",
                    "settings": {
                        "foreground": "#505050"
                    }
                },
                {
                    "scope": "meta.separator.markdown",
                    "settings": {
                        "foreground": "#505050"
                    }
                },
                {
                    "scope": "markup.inline.raw",
                    "settings": {
                        "foreground": "#707070"
                    }
                },
                {
                    "scope": "markup.bold",
                    "settings": {
                        "fontStyle": "bold"
                    }
                },
                {
                    "scope": "markup.italic",
                    "settings": {
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": [
                        "meta.link punctuation.definition.string",
                        "meta.image punctuation.definition.string"
                    ],
                    "settings": {
                        "foreground": "#bfbfbb"
                    }
                },
                {
                    "scope": [
                        "link",
                        "markup.underline.link",
                        "constant.other.reference.link.markdown"
                    ],
                    "settings": {
                        "foreground": "#f996e2"
                    }
                },
                {
                    "scope": "markup.quote",
                    "settings": {
                        "foreground": "#0e8ed8"
                    }
                },
                {
                    "scope": [
                        "entity.name.tag.css",
                        "entity.name.tag.wildcard"
                    ],
                    "settings": {
                        "foreground": "#0ed839"
                    }
                },
                {
                    "scope": [
                        "entity.other.attribute-name.class",
                        "entity.other.attribute-name punctuation.definition.entity"
                    ],
                    "settings": {
                        "foreground": "#505050"
                    }
                },
                {
                    "scope": [
                        "entity.other.attribute-name.pseudo-element",
                        "entity.other.attribute-name.pseudo-class",
                        "constant.other.color"
                    ],
                    "settings": {
                        "foreground": "#707070"
                    }
                },
                {
                    "scope": [
                        "entity.other.attribute-name.id",
                        "entity.other.attribute-name.id punctuation.definition.entity"
                    ],
                    "settings": {
                        "foreground": "#f996e2"
                    }
                },
                {
                    "scope": [
                        "source.css constant.numeric",
                        "source.less constant.numeric",
                        "source.scss constant.numeric"
                    ],
                    "settings": {
                        "foreground": "#0ed839"
                    }
                },
                {
                    "scope": [
                        "meta.property-name",
                        "support.type.property-name"
                    ],
                    "settings": {
                        "foreground": "#0e8ed8"
                    }
                },
                {
                    "scope": [
                        "meta.property-value",
                        "meta.property-value constant.other",
                        "support.constant.property-value"
                    ],
                    "settings": {
                        "foreground": "#f996e2"
                    }
                },
                {
                    "scope": "variable.parameter.url",
                    "settings": {
                        "foreground": "#0e8ed8"
                    }
                },
                {
                    "scope": [
                        "punctuation.section.embedded.begin.php",
                        "punctuation.section.embedded.end.php"
                    ],
                    "settings": {
                        "foreground": "#505050"
                    }
                },
                {
                    "scope": "entity.name.section",
                    "settings": {
                        "foreground": "#f996e2"
                    }
                },
                {
                    "scope": "support.type.property-name.json",
                    "settings": {
                        "foreground": "#505050"
                    }
                },
                {
                    "scope": "markup.inserted",
                    "settings": {
                        "foreground": "#78BD65"
                    }
                },
                {
                    "scope": "markup.changed",
                    "settings": {
                        "foreground": "#399EE6"
                    }
                },
                {
                    "scope": "markup.deleted",
                    "settings": {
                        "foreground": "#F07171"
                    }
                },
                {
                    "scope": "meta.diff.header",
                    "settings": {
                        "foreground": "#399EE6"
                    }
                },
                {
                    "scope": "meta.diff.range",
                    "settings": {
                        "foreground": "#707070"
                    }
                }
            ]
        }
    },
    "python.linting.pylintEnabled": false,
    "python.linting.pylintUseMinimalCheckers": false
}