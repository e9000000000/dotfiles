{
    "launch": {
        "version": "0.2.0",
        "configurations": [
            {
                "name": "docker attach",
                "type": "python",
                "request": "attach",
                "pathMappings": [
                    {
                        "localRoot": "${workspaceFolder}",
                        "remoteRoot": "/service"
                    }
                ],
                "port": 5678,
                "host": "127.0.0.1"
            },
            {
                "name": "debuger attach",
                "type": "python",
                "request": "attach",
                "pathMappings": [
                    {
                        "localRoot": "${workspaceFolder}",
                        "remoteRoot": "${workspaceFolder}"
                    }
                ],
                "port": 5678,
                "host": "127.0.0.1"
            }
        ]
    },
    "python.linting.enabled": true,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": false,
    "breadcrumbs.enabled": false,
    "keyboard.dispatch": "keyCode",
    "editor.formatOnSave": true,
    "editor.renderWhitespace": "none",
    "editor.minimap.enabled": false,
    "python.testing.pytestEnabled": true,
    "python.formatting.provider": "black",
    "workbench.editor.untitled.hint": "hidden",
    "workbench.panel.defaultLocation": "right",
    "comments.openPanel": "openOnSessionStart",
    "workbench.panel.opensMaximized": "never",
    "python.showStartPage": false,
    "editor.fontFamily": "'DejaVu Sans Mono', 'monospace', monospace, 'DejaVu Sans'",
    "security.workspace.trust.enabled": false,
    "python.linting.flake8Enabled": true,
    "editor.linkedEditing": true,
    "files.exclude": {
        ".env/": true,
        "env/": true
    },
    "editor.hover.delay": 200,
    "editor.inlayHints.fontFamily": "'DejaVu Sans Mono', 'monospace', monospace, 'DejaVu Sans'",
    "editor.scrollbar.verticalScrollbarSize": 10,
    "editor.tabCompletion": "on",
    "editor.cursorBlinking": "solid",
    "workbench.tree.indent": 13,
    "workbench.editor.closeOnFileDelete": true,
    "window.menuBarVisibility": "toggle",
    "explorer.autoReveal": false,
    "explorer.openEditors.sortOrder": "alphabetical",
    "explorer.sortOrder": "type",
    "search.exclude": {
        ".env/": true,
        "env/": true
    },
    "debug.console.closeOnEnd": true,
    "python.linting.pylintEnabled": false,
    "python.linting.pylintUseMinimalCheckers": false,
    "docker.showStartPage": false,
    "vscode-neovim.neovimExecutablePaths.linux": "/bin/nvim",
    "vscode-neovim.neovimInitVimPaths.linux": "~/.config/nvim/init.vim",
    "editor.scrollBeyondLastLine": false,
    "python.pythonPath": "/bin/python",
    "workbench.colorCustomizations": {
        "editor.background": "#070707",
        "sideBar.background": "#040404",
        "activityBar.background": "#000000",
        "statusBar.background": "#000000",
        "terminal.background": "#040404",
        "tab.activeBackground": "#070707",
        "tab.inactiveBackground": "#1a1a1a",
        "editor.lineHighlightBackground": "#070707",
        "tab.border": "#1a1a1a",
        "sideBar.border": "#040404",
        "statusBar.border": "#000000",
        "activityBar.border": "#000000",
        "panel.border": "#040404",
        "panel.background": "#040404",
        "sideBarSectionHeader.background": "#000000",
        "sideBarSectionHeader.border": "#000000",
        "editorGroupHeader.tabsBackground": "#040404",
        "editorGroupHeader.border": "#070707",
        "editorOverviewRuler.border": "#070707"
    },
    "editor.tokenColorCustomizations": {
        "comments": "#808080",
        "numbers": "#0DBC79",
        "strings": "#0DBC79"
    }
}