[colors]
background = #e5000000
foreground = #FFFFF0
unfocused = #373730
alert = #e92f2f


[bar/mybar]
wm-restack = bspwm
width = 100%
height = 20
offset-x = 0%
offset-y = 0%
radius = 0.0
fixed-center = false
bottom = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 0
line-color = #00000000

border-size = 0
border-color = #00000000

padding-left = 0
padding-right = 1

module-margin-left = 1
module-margin-right = 1

font-0 = DejaVuSans:size=10.5;4
font-1 = Koruri:size=10.5:style=Bold;3

modules-left = bspwm
modules-center =
modules-right = headphones mic xkeyboard date

tray-position = none
tray-padding = 2
tray-background = ${colors.background}

cursor-click = pointer
cursor-scroll = ns-resize


[module/mic]
type = custom/script
exec = ~/.scripts/polybar_modules/mic.sh
interval = 0.5

format = <label>
label = %output:0:3:%
format-foreground = ${colors.alert}

[module/headphones]
type = custom/script
exec = ~/.scripts/polybar_modules/headphones.sh
interval = 0.5

format = <label>
label = %output:0:10:%
format-foreground = ${colors.alert}


[module/xkeyboard]
type = internal/xkeyboard

blacklist-0 = num lock
blacklist-1 = scroll lock


[module/bspwm]
type = internal/bspwm

ws-icon-0 = 1;一
ws-icon-1 = 2;二
ws-icon-2 = 3;三
ws-icon-3 = 4;四
ws-icon-4 = 5;五
ws-icon-5 = 6;六
ws-icon-6 = 7;七
ws-icon-7 = 8;八
ws-icon-8 = 9;九

label-focused = %icon%
label-focused-foreground = ${colors.foreground}
label-focused-background = ${colors.background}
label-focused-underline= ${colors.primary}
label-focused-padding = 1

label-occupied = %icon%
label-occupied-foreground = ${colors.unfocused}
label-occupied-padding = 1

label-urgent = %icon%
label-urgent-foreground = ${colors.alert}
label-urgent-padding = 1

label-empty = 


[module/date]
type = internal/date
interval = 1

date = %a %m.%d
date-alt = 

time = %I:%M %P
time-alt = time

label = %date% %time%


[settings]
screenchange-reload = true

[global/wm]
margin-top = 0
margin-bottom = 0
