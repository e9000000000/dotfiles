{
  "configurations": {
    "python run main.py": {
      "adapter": "debugpy",
      "filetypes": ["python"],
      "configuration": {
        "request": "launch",
        "program": "-i ${workspaceRoot}/main.py",
        "stopOnEntry": true,
        "cwd": "${workspaceRoot}"
      }
    },
    "python run current file": {
      "adapter": "debugpy",
      "filetypes": ["python"],
      "configuration": {
        "request": "launch",
        "program": "${file}",
        "stopOnEntry": true,
        "cwd": "${workspaceRoot}"
      }
    },
    "python run fastapi": {
      "adapter": "debugpy",
      "filetypes": ["python"],
      "configuration": {
        "name": "fastapi launch",
        "type": "python",
        "request": "launch",
        "python": "${workspaceRoot}/.env/bin/python",
        "module": "uvicorn",
        "cwd": "${workspaceRoot}",
        "args": ["--port", "8000", "--reload", "main:app"]
      }
    }
  }
}
