{
    "workbench.sideBar.location": "right",
    "extensions.ignoreRecommendations": true,
    "git.openRepositoryInParentFolders": "always",
    "explorer.excludeGitIgnore": true,
    "editor.cursorBlinking": "solid",
    "editor.minimap.enabled": false,
    "editor.scrollbar.horizontalScrollbarSize": 0,
    "editor.scrollbar.verticalScrollbarSize": 0,
    "editor.folding": false,
    "editor.foldingHighlight": false,
    "editor.guides.indentation": false,
    "workbench.layoutControl.enabled": false,
    "window.commandCenter": false,
    "terminal.integrated.defaultProfile.windows": "Git Bash",
    "terminal.integrated.tabs.hideCondition": "never",
    "editor.autoClosingBrackets": "never",
    "editor.bracketPairColorization.enabled": false,
    "terminal.integrated.commandsToSkipShell": [
        "-workbench.action.quickOpen"
    ],
    "typescript.suggest.includeAutomaticOptionalChainCompletions": false,
    "javascript.suggest.includeAutomaticOptionalChainCompletions": false,
    "javascript.suggest.enabled": false,
    "typescript.suggest.enabled": false,
    "editor.inlineSuggest.enabled": false,
    "workbench.iconTheme": "vs-minimal",
    "workbench.colorTheme": "Veist",
    "workbench.colorCustomizations": {
        "sideBar.background": "#111",
        "editor.selectionBackground": "#d8477e80",
        "terminal.selectionBackground": "#d8477e80",
        "selection.background": "#d8477e80"
    },
    "editor.renderLineHighlight": "none",
    "workbench.activityBar.visible": false
}